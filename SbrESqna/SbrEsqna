from abc import ABC, abstractmethod

# Classe abstrata
class ItemCardapio(ABC):
    def __init__(self, nome, preco):
        self.__nome = nome
        self.__preco = preco

    def get_nome(self):
        return self.__nome

    def get_preco(self):
        return self.__preco

    @abstractmethod
    def calcular_preco(self):
        pass

    @abstractmethod
    def tempo_preparo(self):
        pass

# Classe Prato
class Prato(ItemCardapio):
    def __init__(self, nome, preco, complexidade):
        super().__init__(nome, preco)
        self.complexidade = complexidade

    def calcular_preco(self):
        return self.get_preco()

    def tempo_preparo(self):
        if self.complexidade == "simples":
            return 15
        elif self.complexidade == "media":
            return 25
        else:
            return 40

# Classe Bebida
class Bebida(ItemCardapio):
    def __init__(self, nome, preco, alcoolica):
        super().__init__(nome, preco)
        self.alcoolica = alcoolica

    def calcular_preco(self):
        return self.get_preco()

    def tempo_preparo(self):
        return 2

# Classe Sobremesa
class Sobremesa(ItemCardapio):
    def __init__(self, nome, preco):
        super().__init__(nome, preco)

    def calcular_preco(self):
        return self.get_preco()

    def tempo_preparo(self):
        return 5

# Classe Pedido
class Pedido:
    def __init__(self, maior_idade):
        self.itens = []
        self.maior_idade = maior_idade

    def adicionar_item(self, item):
        if isinstance(item, Bebida):
            if item.alcoolica and not self.maior_idade:
                print("Não é permitido vender bebida alcoólica para menores.")
                return False

        self.itens.append(item)
        return True

    def aplicar_brinde(self):
        qtd_pratos = 0

        for item in self.itens:
            if isinstance(item, Prato):
                qtd_pratos += 1

        if qtd_pratos >= 3:
            self.itens.append(Sobremesa("Pudim (Brinde)", 0))
            print("Sobremesa de brinde adicionada!")

    def total(self):
        soma = 0
        for item in self.itens:
            soma += item.calcular_preco()
        return soma

    def tempo_total(self):
        tempo = 0
        for item in self.itens:
            tempo += item.tempo_preparo()
        return tempo

    def mostrar_pedido(self):
        print("\nPEDIDO")
        for item in self.itens:
            print(f"- {item.get_nome()} - R$ {item.calcular_preco():.2f}")

        print(f"\nTotal: R$ {self.total():.2f}")
        print(f"Tempo de preparo: {self.tempo_total()} minutos")


# Programa principal
idade = int(input("Digite sua idade: "))
